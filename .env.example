# Claude API (Anthropic) — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx

# Gmail SMTP — use a Gmail App Password (NOT your real password)
# Enable 2FA → Google Account → Security → App passwords → Generate
GMAIL_USER=noreply@hustle.com.my
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Browserless.io — get token from browserless.io dashboard
BLESS_TOKEN=your-browserless-token-here

# Google Sheets
# Create a Google Sheet named "Leads", share it with your service account email
GOOGLE_SHEET_ID=your-sheet-id-here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the full private key from service-account.json
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# App URL (used for metadata)
NEXT_PUBLIC_APP_URL=https://your-domain.com
